# Authoritative multiplayer server configuration.
# Copy to .env for a local run, or provide these via your platform / compose.
# No real credentials belong in this file.

# development | production. Production fails fast on weak/missing values.
NODE_ENV=development

# HTTP + WebSocket bind. HOST defaults to 0.0.0.0 (production) / 127.0.0.1 (dev).
HOST=0.0.0.0
PORT=8080

# PostgreSQL connection string (REQUIRED). There is no in-memory fallback.
DATABASE_URL=postgresql://assalto:assalto@127.0.0.1:5432/assalto_reale

# Comma-separated browser origin allowlist (REQUIRED in production).
MULTIPLAYER_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# WebSocket upgrade path (default /ws). The HTTP session route is fixed at /session.
WEBSOCKET_PATH=/ws

# Guest-session HMAC secret. REQUIRED in production; must be >= 32 bytes; never
# logged. In development a clearly-labelled placeholder is used when unset.
GUEST_SESSION_SECRET=change-me-to-a-strong-random-secret-of-32-plus-bytes

# Optional tuning (defaults shown).
# GUEST_SESSION_TTL_SECONDS=43200
# HEARTBEAT_INTERVAL_MS=30000
# MAX_PAYLOAD_BYTES=65536
# MAX_BUFFERED_BYTES=1048576
# SHUTDOWN_GRACE_MS=10000
