{
  "name": "@assalto-reale/server-runtime",
  "version": "1.0.0-beta.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "assalto-multiplayer-server": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "deps:build": "npm --prefix ../server-transport run build",
    "typecheck": "npm run deps:build && tsc -p tsconfig.json --noEmit --pretty false",
    "build": "npm run deps:build && tsc -p tsconfig.build.json --pretty false",
    "start": "node dist/main.js",
    "test": "npm run deps:build && vitest run --config vitest.config.ts",
    "test:coverage": "npm run deps:build && vitest run --config vitest.config.ts --coverage",
    "lint": "node ../../web/node_modules/eslint/bin/eslint.js --config ../../web/eslint.config.js src tests scripts --max-warnings 0",
    "format:check": "prettier --check .",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "audit:prod": "npm audit --omit=dev"
  },
  "dependencies": {
    "@assalto-reale/authoritative-server": "file:../authoritative-server",
    "@assalto-reale/multiplayer-protocol": "file:../multiplayer-protocol",
    "@assalto-reale/server-transport": "file:../server-transport",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.8",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=20"
  }
}
