# Web client multiplayer configuration. Copy to web/.env.local to enable online
# play against a running backend. Without VITE_MULTIPLAYER_WS_URL the client
# fails closed: online play stays disabled and shows "Server not configured".

# Backend WebSocket URL. For the local docker-compose stack (docker compose up):
VITE_MULTIPLAYER_WS_URL=ws://127.0.0.1:8080/ws

# Optional explicit HTTP session endpoint. When unset it is derived from
# VITE_MULTIPLAYER_WS_URL: ws->http (wss->https) on the same origin at /session
# (e.g. ws://127.0.0.1:8080/ws -> http://127.0.0.1:8080/session).
# VITE_MULTIPLAYER_SESSION_URL=http://127.0.0.1:8080/session

# Production must use TLS on an allowlisted origin, e.g.:
# VITE_MULTIPLAYER_WS_URL=wss://play.example.com/ws
